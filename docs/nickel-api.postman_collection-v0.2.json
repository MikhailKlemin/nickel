						}
					],
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\"category\": \"Alimentation\"}"
						},
						"url": {
							"raw": "{{base_url}}/v1/transactions/{{transaction_id}}/category",
							"host": [
								"{{base_url}}"
							],
							"path": [
